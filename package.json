{
  "name": "careerpilot-ai",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "check:mongo": "node scripts/check-mongo.mjs",
    "mongo:start": "node scripts/start-mongo.mjs",
    "verify:auth": "node scripts/verify-auth-full.mjs",
    "verify:resume": "node scripts/verify-resume.mjs",
    "free-ports": "node scripts/free-ports.mjs",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "wait-on -t 120000 http-get://127.0.0.1:5000/api/health && vite",
    "predev": "node scripts/free-ports.mjs",
    "predev:nocheck": "node scripts/free-ports.mjs",
    "dev": "node scripts/start-mongo.mjs && concurrently -n api,web -c magenta,cyan \"npm run dev:server\" \"npm run dev:client\"",
    "dev:nocheck": "concurrently -n api,web -c magenta,cyan \"npm run dev:server\" \"npm run dev:client\"",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@react-oauth/google": "^0.13.5",
    "axios": "^1.7.9",
    "framer-motion": "^11.15.0",
    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "docx": "^9.6.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  }
}
